# Declarative manifest for winter-service-docker (TOML format).
# Copy this to workspace:/.winter/config/winter-service-docker/config.toml and customize.
#
# This file is the live configuration for the docker_orchestrator package. It
# describes every service in a structured, machine-readable format consumed at
# runtime. The loader reads config.toml from the extension config dir (resolved
# via WINTER_EXT_CONFIG_DIR on every dispatch, or falling back to
# <workspace-root>/.winter/config/winter-service-docker/).
#
# Scaffold a starter config with:
#   PYTHONPATH=src python3 -m docker_orchestrator.scaffold <dest-dir>

# Prefix for COMPOSE_PROJECT_NAME.  Each env's compose project is named
# <prefix>-<env> (e.g. "myapp-alpha", "myapp-beta") so containers,
# networks, and volumes are automatically namespaced per env and never collide.
# The workspace scope uses <prefix>-workspace.
#
# <prefix> is controlled by the workspace-level WINTER_SERVICE_PREFIX,
# injected by winter-cli core (resolved from `service_prefix` in the
# workspace's .winter/config.toml) on every dispatch action, including
# restart/logs — nothing to configure here. project_prefix below is a
# purely optional, hand-edited override: only relevant if this provider
# needs a different prefix than the rest of the workspace.
# project_prefix = "myapp"

# Path to the compose file for per-env (project-scoped) services.
# Contains ONLY project-scoped services — independently runnable by hand
# (source the scope env first with `source <(winter env <scope>)`; see context/provider-contract.md#environment-variable-injection).
# Relative paths are resolved relative to this config dir (alongside config.toml).
# Absolute paths are used as-is.
environment_compose_file = "environment-compose.yaml"

# Path to the compose file for workspace-scoped singleton services.
# Contains ONLY workspace-scoped services — independently runnable by hand
# (source the scope env first with `source <(winter env <scope>)`; see context/provider-contract.md#environment-variable-injection).
# Relative paths are resolved relative to this config dir (alongside config.toml).
# Absolute paths are used as-is.
workspace_compose_file = "workspace-compose.yaml"

# ---------------------------------------------------------------------------
# Services — declare every service winter should manage.
#
# Fields:
#   name  (required) — unique identifier used in restart and logs patterns.
#                      Names are globally unique across both scopes.
#   scope (optional, default "project") — "project" runs the service in the
#                      per-env <prefix>-<env> compose project (declared
#                      in environment_compose_file); "workspace" makes it a
#                      workspace-scoped singleton that runs in
#                      <prefix>-workspace (declared in
#                      workspace_compose_file, shared across all feature envs).
#                      Drive workspace services with
#                      `winter service up/down workspace`.
#
# WSD_PORT_<NAME> port-substitution convention:
#   Published host ports in environment-compose.yaml should use ${WSD_PORT_<NAME>}
#   placeholders where <NAME> is the UPPER-CASED service name.
#   winter-service-docker substitutes WINTER_PORT_BASE + <position> at runtime,
#   where <position> is the 0-based declaration order among PROJECT-scoped
#   [[service]] entries (workspace-scoped entries are excluded from port
#   assignment because they have no WINTER_PORT_BASE). Reordering project
#   entries reassigns ports.
#
#   Example with WINTER_PORT_BASE=4060 (gamma env), project-scoped services only:
#     backend (position 0) → WSD_PORT_BACKEND = 4060
#     worker  (position 1) → WSD_PORT_WORKER  = 4061
#   Reordering these two entries would swap their ports. Alpha (port_base=4020),
#   beta (4040), and gamma (4060) each get unique host ports automatically.
#
#   Workspace-scoped services get no WSD_PORT_* (that per-env auto-derivation
#   needs a per-env WINTER_PORT_BASE, which the workspace scope has not). Use
#   fixed host ports in workspace-compose.yaml, or reference
#   ${WINTER_WORKSPACE_PORT_BASE} (injected by core for the workspace scope).
# ---------------------------------------------------------------------------

[[service]]
name = "backend"
# scope = "project"  # default — runs per-env in <prefix>-<env>

[[service]]
name = "worker"
# scope = "project"  # default — runs per-env in <prefix>-<env>

# ---------------------------------------------------------------------------
# Workspace-scoped singleton services
# ---------------------------------------------------------------------------
#
# A [[service]] entry with scope = "workspace" runs in a SEPARATE compose
# project named <prefix>-workspace, created once for the whole
# workspace rather than once per feature env.  These are shared across all
# feature environments and are intended for long-running infrastructure that
# should not be duplicated per-env (e.g. a shared database, a registry).
#
# scope is the only field that distinguishes a workspace singleton from a
# per-env service:
#   scope = "project"   (DEFAULT, may be omitted) — per-env service, runs in
#                       the <prefix>-<env> compose project.
#   scope = "workspace" — workspace singleton, runs in <prefix>-workspace.
# The name field is declared the same way as for any project service.
#
# Name uniqueness is GLOBAL across both scopes — a project and a workspace
# service may not share a name.

[[service]]
# Shared database singleton — runs once in <prefix>-workspace.
# No WSD_PORT_DB is emitted; use a fixed port in workspace-compose.yaml.
name = "db"
scope = "workspace"
